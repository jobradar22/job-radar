# Copy this file to ".env" and fill in only what you need. Everything is optional.

# How often (minutes) to auto-check for new jobs
REFRESH_MINUTES=30

# Server (0.0.0.0 lets your phone reach it on the same Wi-Fi)
HOST=0.0.0.0
PORT=8000

# ---------- Login / accounts ----------
# Each person registers their own username + password and saves their preferred
# job role. A long random string signs the login cookie. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-please-set-SECRET_KEY
# OPTIONAL: require an invite code to create an account (stops random public
# signups once the app is on the internet). Leave blank to allow open signup.
REGISTRATION_CODE=

# ---------- Email notifications (optional) ----------
# Example below is for Gmail. Use a Gmail "App Password", NOT your real password.
# Create one at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youraddress@gmail.com
SMTP_PASS=your_16_char_app_password
EMAIL_FROM=youraddress@gmail.com
# (Each user gets alerts at the email saved in their own profile — no EMAIL_TO.)

# ---------- Adzuna (optional) — adds Bangalore/India job listings ----------
# Free key (takes 1 minute): https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=in
